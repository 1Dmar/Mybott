{
  "name": "discord.js-anticrash",
  "version": "4.0.3-devbuild",
  "description": "Advanced, customizable, and user-friendly error-handling enhancements for Discord bots using discord.js.",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "tsc && tsc-watch --onSuccess \"npm run build:cjs && npm run build:esm\"",
    "build:cjs": "tsc --module commonjs --outDir dist",
    "build:esm": "tsc --module esnext --outDir dist/esm",
    "lint": "eslint .",
    "test": "jest",
    "audit": "npm audit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Alpha5959/discord.js-anticrash.git"
  },
  "keywords": [
    "anticrash",
    "discord.js",
    "discord-anticrash",
    "error-handling",
    "discord bot",
    "discord.js-anticrash"
  ],
  "author": "xkroenen",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/Alpha5959/discord.js-anticrash/issues"
  },
  "homepage": "https://github.com/Alpha5959/discord.js-anticrash#readme",
  "dependencies": {
    "colors": "^1.4.0"
  },
  "devDependencies": {
    "@types/jest": "^29.2.4",
    "@types/node": "^18.11.9",
    "eslint": "^8.38.0",
    "eslint-config-prettier": "^8.8.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "tsc-watch": "^5.0.3",
    "typescript": "^5.0.4"
  },
  "engines": {
    "node": ">=18.6.0"
  }
}
